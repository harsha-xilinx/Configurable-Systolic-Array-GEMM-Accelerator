// BAasic PE by chatgpt
module pe #(
  parameter DW = 8,
  parameter ACCW = 32
) (
  input logic clk, rst_n,
  input logic [DW-1:0] A_in,
  input logic A_valid,
  input logic [DW-1:0] B_in,
  input logic B_valid,
  input logic clear_acc,
  output logic [DW-1:0] A_out,
  output logic A_out_valid,
  output logic [DW-1:0] B_out,
  output logic B_out_valid,
  output logic [ACCW-1:0] acc_out,
  output logic acc_out_valid
);

  logic [ACCW-1:0] acc;
  logic [DW*2-1:0] prod;

  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      acc <= '0;
    end else begin
      if (clear_acc) acc <= '0;
      else if (A_valid && B_valid) acc <= acc + $signed(A_in) * $signed(B_in);
    end
  end

  // pass-through
  assign A_out = A_in;
  assign A_out_valid = A_valid;
  assign B_out = B_in;
  assign B_out_valid = B_valid;

  // output when controller decides tile done: (controller will sample acc)
  assign acc_out = acc;
  // controller is responsible to latch acc_out when acc_out_valid asserted
  assign acc_out_valid = /* wired to controller once done */ 1'b0;

endmodule
